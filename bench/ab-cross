#!/usr/bin/env python3
"""Head-to-head jet benchmark vs lua, python, and jsc for a single git ref.

Builds the jet ref in a temp worktree, then for each bench runs jet against
every available comparand (lua, python, jsc), interleaving the
runs per iteration. Reports per-bench median time, ratio, and jet's
wins/ties/losses with a one-sided binomial p-value, plus an overall geomean
ratio per comparand. A bench whose comparand source is missing is skipped for
that comparand only; missing .ss is fatal.

Usage:
    ./ab-cross [<ref>] [-n RUNS] [-b BENCH ...] [--keep]

Set LUA, PYTHON, or JSC to an empty string to disable that comparand. Set
JSC_VERSION when JSC does not point into Apple's JavaScriptCore framework.

Examples:
    ./ab-cross                       # use HEAD
    ./ab-cross HEAD~1
    ./ab-cross perf-branch -n 30 -b bench-fib -b bench-tak
"""
import argparse
import os
import plistlib
import shutil
import statistics
import subprocess
import sys
import tempfile
import time
from math import comb
from pathlib import Path

HERE = Path(__file__).resolve().parent
REPO = HERE.parent
DEFAULT_BENCHES = sorted(p.stem for p in HERE.glob("bench-*.ss"))
SYSTEM_JSC = Path("/System/Library/Frameworks/JavaScriptCore.framework/Versions/A/Helpers/jsc")


def die(msg):
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(1)


def run(cmd, **kw):
    r = subprocess.run(cmd, **kw)
    if r.returncode != 0:
        die(f"command failed (exit {r.returncode}): {' '.join(map(str, cmd))}")
    return r


def short(ref):
    r = subprocess.run(["git", "rev-parse", "--short", ref], cwd=REPO,
                       capture_output=True, text=True)
    return r.stdout.strip() if r.returncode == 0 else ref


def build_ref(ref, dest):
    print(f"  building {ref} ({short(ref)}) at {dest} ...", flush=True)
    run(["git", "worktree", "add", "--detach", str(dest), ref], cwd=REPO,
        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    cmd = ["make", "-j"]
    if "CXX" in os.environ:
        cmd.append(f"CXX={os.environ['CXX']}")
    run(cmd, cwd=dest, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    bin = dest / "build" / "jet"
    if not bin.exists():
        die(f"build did not produce {bin}")
    return bin


def remove_worktree(dest):
    subprocess.run(["git", "worktree", "remove", "--force", str(dest)],
                   cwd=REPO, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def time_run(cmd):
    s = time.perf_counter()
    r = subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    dt = time.perf_counter() - s
    if r.returncode != 0:
        die(f"benchmark exited {r.returncode}: {' '.join(map(str, cmd))}")
    return dt


def lua_version(lua):
    r = subprocess.run([lua, "-v"], capture_output=True, text=True)
    return (r.stderr.strip() or r.stdout.strip()).splitlines()[0]


def python_version(py):
    r = subprocess.run([py, "-V"], capture_output=True, text=True)
    return (r.stdout.strip() or r.stderr.strip()).splitlines()[0]


def jsc_version(jsc):
    if "JSC_VERSION" in os.environ:
        return os.environ["JSC_VERSION"] or "version unavailable"
    path = Path(jsc).resolve()
    framework = next((p for p in (path, *path.parents)
                      if p.name == "JavaScriptCore.framework"), None)
    if framework is None:
        return "version unavailable"
    plist = framework / "Resources" / "Info.plist"
    try:
        with plist.open("rb") as f:
            info = plistlib.load(f)
    except (OSError, plistlib.InvalidFileException):
        return "version unavailable"
    release = info.get("CFBundleShortVersionString")
    build = info.get("CFBundleVersion")
    if release and build and release != build:
        return f"{release}, build {build}"
    return str(release or build or "version unavailable")


def sign_p(wins, n_decisive):
    if n_decisive == 0:
        return 1.0
    one_sided = sum(comb(n_decisive, k) for k in range(wins, n_decisive + 1)) / 2 ** n_decisive
    losses = n_decisive - wins
    other_tail = sum(comb(n_decisive, k) for k in range(losses, n_decisive + 1)) / 2 ** n_decisive
    return min(1.0, 2 * min(one_sided, other_tail))


def fmt_p(p):
    if p < 1e-6:
        return f"{p:.0e}"
    if p < 0.01:
        return f"{p:.4f}"
    return f"{p:.3f}"


def main():
    ap = argparse.ArgumentParser(
        description="Head-to-head jet benchmark vs lua and python for a single git ref.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__)
    ap.add_argument("ref", nargs="?", default="HEAD",
                    help="git ref to build (default HEAD)")
    ap.add_argument("-n", "--runs", type=int, default=20,
                    help="trials per interpreter per bench (default 20)")
    ap.add_argument("-b", "--bench", action="append",
                    help="restrict to specific bench (repeatable)")
    ap.add_argument("--keep", action="store_true",
                    help="keep temp worktree after run")
    args = ap.parse_args()

    benches = args.bench or DEFAULT_BENCHES

    if "LUA" in os.environ:
        lua = os.environ["LUA"] or None
    else:
        lua = shutil.which("lua")
    if "PYTHON" in os.environ:
        py = os.environ["PYTHON"] or None
    else:
        py = shutil.which("python3") or shutil.which("python")
    if "JSC" in os.environ:
        jsc = os.environ["JSC"] or None
    else:
        jsc = shutil.which("jsc")
        if jsc is None and SYSTEM_JSC.exists():
            jsc = str(SYSTEM_JSC)
    if lua is None and py is None and jsc is None:
        die("no comparand found (or enabled with LUA/PYTHON/JSC env)")

    r = subprocess.run(["git", "rev-parse", "--verify", f"{args.ref}^{{commit}}"],
                       cwd=REPO, capture_output=True)
    if r.returncode != 0:
        die(f"unknown git ref: {args.ref}")

    tmp = Path(tempfile.mkdtemp(prefix="ab-cross-"))
    wt = tmp / "jet"
    bin_jet = build_ref(args.ref, wt)

    print()
    print(f"  ref:    {args.ref} ({short(args.ref)})  →  {bin_jet}")
    if lua:
        print(f"  lua:    {lua}  ({lua_version(lua)})")
    if py:
        print(f"  python: {py}  ({python_version(py)})")
    if jsc:
        print(f"  jsc:    {jsc}  ({jsc_version(jsc)})")
    print(f"  runs:   {args.runs} per interpreter per bench, interleaved")
    print()

    sources_by_bench = {}
    for b in benches:
        ss_src = HERE / f"{b}.ss"
        if not ss_src.exists():
            die(f"missing scheme source: {ss_src}")
        sources = {}
        if lua and (HERE / f"{b}.lua").exists():
            sources["lua"] = HERE / f"{b}.lua"
        if py and (HERE / f"{b}.py").exists():
            sources["python"] = HERE / f"{b}.py"
        if jsc and (HERE / f"{b}.js").exists():
            sources["jsc"] = HERE / f"{b}.js"
        sources_by_bench[b] = (ss_src, sources)

    name_w = max(len(b) for b in benches)
    header = (f"  {'bench':<{name_w}}  {'vs':<6} {'jet(ms)':>9} {'rival(ms)':>10}  "
              f"{'ratio':>6}  {'wins/ties/losses':>17}  {'p':>10}")
    print(header)
    print("  " + "-" * (len(header) - 2))

    ratios_by_lang = {"lua": [], "python": [], "jsc": []}
    cmd_for = {
        "lua": lambda src: [lua, str(src)],
        "python": lambda src: [py, str(src)],
        "jsc": lambda src: [jsc, "--useJIT=false", str(HERE / "run-jsc-benchmark.js"),
                            "--", str(HERE / "js"), str(src), src.stem],
    }

    for b in benches:
        ss_src, sources = sources_by_bench[b]
        if not sources:
            print(f"  {b:<{name_w}}  (no comparand source)")
            continue
        for lang, src in sources.items():
            cmd_jet = [str(bin_jet), "run", str(ss_src)]
            cmd_rival = cmd_for[lang](src)
            # warmup
            time_run(cmd_jet)
            time_run(cmd_rival)
            jet_t, rival_t = [], []
            wins = ties = losses = 0
            for i in range(args.runs):
                if i % 2 == 0:
                    c = time_run(cmd_jet)
                    r_t = time_run(cmd_rival)
                else:
                    r_t = time_run(cmd_rival)
                    c = time_run(cmd_jet)
                jet_t.append(c)
                rival_t.append(r_t)
                if c < r_t:
                    wins += 1
                elif c > r_t:
                    losses += 1
                else:
                    ties += 1
            med_c = statistics.median(jet_t)
            med_r = statistics.median(rival_t)
            ratio = med_c / med_r if med_r > 0 else 1.0
            ratios_by_lang[lang].append(ratio)
            p = sign_p(wins, wins + losses)
            print(f"  {b:<{name_w}}  {lang:<6} {med_c*1000:>9.2f} {med_r*1000:>10.2f}  "
                  f"{ratio:>5.2f}×  {wins:>3}/{ties:>3}/{losses:>3}    {fmt_p(p):>10}")

    print()
    for lang, ratios in ratios_by_lang.items():
        if len(ratios) >= 2:
            gm = statistics.geometric_mean(ratios)
            print(f"  geomean ratio (jet/{lang}): {gm:.3f}×  ({len(ratios)} benches)")
        elif len(ratios) == 1:
            print(f"  ratio (jet/{lang}): {ratios[0]:.3f}×  (1 bench)")

    if not args.keep:
        remove_worktree(wt)
    else:
        print(f"\n  worktree kept: {wt}")


if __name__ == "__main__":
    main()
